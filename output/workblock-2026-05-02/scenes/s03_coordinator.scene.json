  "narration": {
    "text": "This is the Coordinator Queue — the command center where work gets routed. Nine tasks are waiting, and each one needs a decision before work can start. On the left, every pending task — grouped by project so you always see the context first. Tasks live under their project, so you never assign blind. A green Signed Off tag means the brief is locked — this one's ready for a teammate. Purple flags a scope change — the coordinator decides whether to re-plan or push it back. Amber means the client hasn't signed off yet — these wait, but stay visible so nothing gets lost. Every row carries an overdue counter, so the most urgent work pulls your eye first. Right now the right pane is empty — it's the workspace, waiting for a task. The flow is simple — pick a task on the left, and the right pane fills with everything you need to assign it, split it, or send it back. That's the whole loop.",
    "ssml": "<speak><prosody rate=\"medium\">This is the Coordinator Queue<break time=\"160ms\"/> — the command center where work gets routed.<break time=\"380ms\"/> Nine tasks are waiting,<break time=\"160ms\"/> and each one needs a decision before work can start.<break time=\"420ms\"/> On the left, every pending task<break time=\"140ms\"/> — grouped by project so you always see the context first.<break time=\"380ms\"/> Tasks live under their project,<break time=\"140ms\"/> so you never assign blind.<break time=\"380ms\"/> A green <emphasis level=\"moderate\">Signed Off</emphasis> tag means the brief is locked<break time=\"140ms\"/> — this one's ready for a teammate.<break time=\"380ms\"/> Purple flags a <emphasis level=\"moderate\">scope change</emphasis><break time=\"140ms\"/> — the coordinator decides whether to re-plan or push it back.<break time=\"380ms\"/> Amber means the client hasn't signed off yet<break time=\"140ms\"/> — these wait, but stay visible so nothing gets lost.<break time=\"380ms\"/> Every row carries an <emphasis level=\"moderate\">overdue counter</emphasis>,<break time=\"140ms\"/> so the most urgent work pulls your eye first.<break time=\"420ms\"/> Right now the right pane is empty<break time=\"140ms\"/> — it's the workspace, waiting for a task.<break time=\"420ms\"/> The flow is simple<break time=\"160ms\"/> — pick a task on the left,<break time=\"180ms\"/> and the right pane fills with everything you need to assign it, split it, or send it back.<break time=\"380ms\"/> <emphasis level=\"strong\">That's the whole loop.</emphasis></prosody></speak>",
    "alignments": [
      { "t_ms": 200, "text": "This is the Coordinator Queue — the command center where work gets routed." },
      { "t_ms": 6100, "text": "Nine tasks are waiting, and each one needs a decision before work can start." },
      { "t_ms": 12100, "text": "On the left, every pending task — grouped by project so you always see the context first." },
      { "t_ms": 20100, "text": "Tasks live under their project, so you never assign blind." },
      { "t_ms": 25600, "text": "A green Signed Off tag means the brief is locked — this one's ready for a teammate." },
      { "t_ms": 31600, "text": "Purple flags a scope change — the coordinator decides whether to re-plan or push it back." },
      { "t_ms": 37600, "text": "Amber means the client hasn't signed off yet — these wait, but stay visible so nothing gets lost." },
      { "t_ms": 43600, "text": "Every row carries an overdue counter, so the most urgent work pulls your eye first." },
      { "t_ms": 50100, "text": "Right now the right pane is empty — it's the workspace, waiting for a task." },
      { "t_ms": 58600, "text": "The flow is simple — pick a task on the left," },
      { "t_ms": 68100, "text": "and the right pane fills with everything you need to assign it, split it, or send it back." },
      { "t_ms": 78000, "text": "That's the whole loop." }
    ]
  }
